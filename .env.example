# Copy this file to .env.local for local development:  cp .env.example .env.local
# .env.local is git-ignored. NEVER put production secrets here.
# Production values are set in the Vercel dashboard (Settings > Environment Variables,
# scope = Production), NOT in any file in this repo. (.env.production.local is also
# git-ignored and used only to point CLI tools — migrate/seed — at the prod DB.)

# ============================================================================
# Runtime (read by the Next.js app)
# ============================================================================

# Turso / libSQL database.
#   Local dev  → a file DB, no auth token needed (leave as-is below).
#   Production → set in Vercel:  TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
#                                TURSO_AUTH_TOKEN="<prod token>"
# A "file:" URL is treated as local; "libsql://" / "https://" / "wss://" as remote
# (the seed scripts refuse to write mock data to a remote URL).
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# Session cookie name for the custom auth (the httpOnly cookie that holds the
# server session id). Any non-empty string; keep it stable across deploys.
SESSION_COOKIE_NAME="es_session"

# PromptPay target shown in the shop's "เติมวัน" (day top-up) QR — a mobile number,
# national id, or tax id. Money is transferred to this account.
PROMPTPAY_TARGET="0000000000"

# APP_URL (OPTIONAL) — absolute base URL for links embedded in QR codes.
# Leave UNSET in most cases: the app derives the base URL from request headers
# (x-forwarded-host on Vercel, localhost in dev). Set it only to pin a single
# canonical domain (e.g. force the custom domain even when accessed via *.vercel.app).
# APP_URL="https://your-domain.com"

# Cloudflare R2 — object storage for uploaded payment slips.
#   Local dev: leave UNSET → slips fall back to local disk (./uploads/slips).
#   Production (Vercel): set all four. Vercel's filesystem is ephemeral, so the
#   local fallback CANNOT be used there — uploads need R2.
# Create a bucket + an R2 API token (Object Read & Write) in the Cloudflare
# dashboard. The bucket stays PRIVATE; slips are served through the auth-gated
# /api/slips route, never a public URL.
# R2_ACCOUNT_ID="<cloudflare account id>"
# R2_ACCESS_KEY_ID="<r2 access key id>"
# R2_SECRET_ACCESS_KEY="<r2 secret access key>"
# R2_BUCKET="<bucket name>"
# R2_ENDPOINT (OPTIONAL) — override the endpoint; defaults to
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=""

# Geocoding for the lead map picker (/admin/leads/new) — POI lookup, reverse
# geocode, place search. All OPTIONAL: free OpenStreetMap endpoints are used by
# default (no signup, no key). Overpass + Nominatim have fair-use limits — fine
# for low-volume admin prospecting.
#   - GEO_USER_AGENT: Nominatim's usage policy REQUIRES a descriptive User-Agent.
#     In production set one that includes a contact, e.g.
#     "EasyStamp/1.0 (https://easy-stamp-nextjs.vercel.app; you@example.com)".
#   - Swap the two URLs to a keyed provider (Geoapify/LocationIQ/self-hosted) for
#     better Thai coverage / reliability without any code change.
# OSM_OVERPASS_URL="https://overpass-api.de/api/interpreter"
# OSM_NOMINATIM_URL="https://nominatim.openstreetmap.org"
# GEO_USER_AGENT="EasyStamp/1.0 (+admin lead tool)"

# LINE Messaging API — push notifications to operators (admin + shop owners).
#   Leave UNSET → LINE push is disabled (in-app notifications still work).
#   To enable: create a LINE Official Account + a Messaging API channel, then set
#   both tokens below and point the channel's Webhook URL at:
#     https://<your-domain>/api/line/webhook
# LINE_CHANNEL_ACCESS_TOKEN="<long-lived channel access token>"
# LINE_CHANNEL_SECRET="<channel secret — used to verify webhook signatures>"
# NEXT_PUBLIC_LINE_OA_ADD_URL (OPTIONAL) — the OA "add friend" link shown in the
#   in-app LINE-link card, e.g. https://line.me/R/ti/p/@your-oa-id
# NEXT_PUBLIC_LINE_OA_ADD_URL=""

# Cloudflare Turnstile — CAPTCHA on the public "contact admin" form (login page).
#   Leave UNSET → CAPTCHA disabled (fine for local dev). Set BOTH in production to
#   enforce it. Create a widget at https://dash.cloudflare.com → Turnstile.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="<turnstile site key — public>"
# TURNSTILE_SECRET_KEY="<turnstile secret key — server only>"

# ============================================================================
# Seeding (read ONLY by scripts/seed.ts — not needed at runtime)
#
#   Local:  not required. `npm run db:seed` falls back to dev defaults
#           (admin@easystamp.test / owner@demo.easystamp.test, password "password123").
#   Remote: REQUIRED. Seeding the `production` profile to a remote DB throws unless
#           both SEED_ADMIN_PASSWORD and SEED_DEMO_OWNER_PASSWORD are set — the app
#           has no in-app password change, so default passwords must never reach prod.
#           Pass them inline, e.g.:
#             SEED_ADMIN_PASSWORD='...' SEED_DEMO_OWNER_PASSWORD='...' \
#               npm run db:seed:prod -- --env=.env.production.local
# ============================================================================

# SEED_ADMIN_EMAIL (OPTIONAL) — platform admin login created by the seed.
# Defaults to admin@easystamp.test when unset.
# SEED_ADMIN_EMAIL="admin@easystamp.test"

# SEED_ADMIN_PASSWORD — password for the platform admin account.
# Required when seeding production to a remote DB.
# SEED_ADMIN_PASSWORD=""

# SEED_DEMO_OWNER_PASSWORD — password for the example shop owner (owner@demo.easystamp.test).
# Required when seeding production to a remote DB.
# SEED_DEMO_OWNER_PASSWORD=""

# CRON_SECRET — bearer token guarding the cron dispatcher (/api/cron). Vercel
# injects this header automatically when the env var is set on the project.
# Generate a random value, e.g. `openssl rand -hex 32`.
# CRON_SECRET=""

# A single Vercel cron (Hobby tier = 1 schedule) hits /api/cron, which runs every
# enabled job in one pass. Toggle individual jobs by setting these to off/false/0
# (unset = on). On a paid plan you can instead add /api/cron?job=<id> entries to
# vercel.json on separate schedules.
# CRON_LEAD_FOLLOWUPS="on"
# CRON_CLEANUP="on"
# CRON_ORPHANED_FILES="on"   # delete uploaded blobs no longer referenced by any row

# ============================================================================
# Observability (logging + error tracking) — all OPTIONAL
# ============================================================================
# The app logs through a structured logger (JSON lines in production, a compact
# human line in dev). Tune it with:
# LOG_LEVEL — debug | info | warn | error | silent (default: info in prod, debug in dev)
# LOG_LEVEL="info"
# LOG_FORMAT — "json" to force JSON lines outside production (default: pretty in dev)
# LOG_FORMAT="json"
#
# ERROR_WEBHOOK_URL (OPTIONAL) — when set, logger.captureException() also POSTs a
# JSON error report here (Slack/Discord incoming webhook, or any collector).
# Vendor-neutral and fail-soft; leave UNSET to keep error tracking a no-op. To
# use a full APM (e.g. Sentry) instead, implement ErrorTracker in
# src/infrastructure/observability/error-tracker.ts.
# ERROR_WEBHOOK_URL=""

# ============================================================================
# Transactional email (Resend) — OPTIONAL
# ============================================================================
# When BOTH are set, notifications (payment results, contact updates, security
# alerts) are also emailed to the user, in addition to in-app + LINE. Leave
# UNSET to keep email a no-op (NotificationService just skips it). Fail-soft.
# To use a different provider (SES/Postmark/SMTP), implement IEmailSender and
# select it in src/infrastructure/services/ResendEmailSender.ts → createEmailSender().
# RESEND_API_KEY="<resend api key>"
# EMAIL_FROM="Easy Stamp <no-reply@yourdomain.com>"
