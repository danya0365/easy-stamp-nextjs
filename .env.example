# Turso / libSQL. Local dev can use a file DB (no auth token needed).
# For production, set to your Turso libsql:// URL + auth token.
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# Session cookie name for the custom auth.
SESSION_COOKIE_NAME="es_session"

# PromptPay target for the monthly subscription QR (phone or national id / tax id).
PROMPTPAY_TARGET="0000000000"

# Public base URL used to build links embedded in customer QR codes.
# Leave blank in dev (derived from request host); set in production, e.g. https://app.example.com
APP_URL=""
